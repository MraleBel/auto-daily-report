{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Daily Report",
  "version": "1.0.7",
  "identifier": "com.autodailyreport.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Auto Daily Report",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGNUI2MUJENENBMTAwQ0IKUldUTEFLRk12V0ZianlyeXBxRlRSekdJOEhQTENVWUdJS2pLUUQxekd2cUhHbFBZMDZSM2hXcXMK",
      "endpoints": [
        "https://github.com/MraleBel/auto-daily-report/releases/latest/download/latest.json"
      ]
    }
  }
}
